# Copy this file to .env and fill in your keys. .env is gitignored — never commit real keys.

# Cohere Rerank (free tier) — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Gemini — kept for CLAUDE.md's original spec but currently unused by
# scripts/evaluate.py (see CLAUDE.md "Deviation from spec"):
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic (Claude), used as the RAGAS judge model in scripts/evaluate.py —
# requires API billing at console.anthropic.com (separate from a Claude Pro
# chat subscription): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
